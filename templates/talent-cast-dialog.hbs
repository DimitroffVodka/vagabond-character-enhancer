{{!--
  talent-cast-dialog.hbs
  Cast configuration dialog for Psychic Talents.
  Rendered by TalentCast.openDialog() — context shape:
    talent          — Talent item document
    cap             — floor(psychicLevel / 2)
    hasDamage       — boolean: talent has a damage field
    hasEffect       — boolean: talent has an effect field
    allowedDeliveries — all delivery keys the talent permits (full list)
    initialDeliveries — delivery keys affordable at cap budget (first-render filter)
    deliveryCosts   — DELIVERY_COSTS map { touch:0, cone:2, … }
--}}
<form class="vce-creature-picker vce-talent-cast-dialog">

  {{!-- Live Mana counter --}}
  <div class="vce-tc-header">
    <span class="vce-tc-talent-name">{{talent.name}}</span>
    <span class="vce-tc-counter">Spent: 0 / {{cap}}</span>
  </div>

  <div class="vce-tc-body">

    {{!-- Damage row --}}
    {{#if hasDamage}}
    <div class="vce-tc-row">
      <label class="vce-tc-label vce-tc-inline">
        <input type="checkbox" name="includeDamage" checked />
        Include damage (1d6{{#if talent.system.damageType}} {{talent.system.damageType}}{{/if}})
      </label>
      <div class="vce-tc-slider-row">
        <label class="vce-tc-sublabel">Extra dice:</label>
        <input type="range" name="damageDice" min="0" max="{{initialSliderMax}}" value="0" step="1" class="vce-tc-slider" />
        <span class="vce-tc-dice-val">+0d6</span>
        <span class="vce-tc-cost-note">(+1 Mana each)</span>
      </div>
    </div>
    {{/if}}

    {{!-- Effect row --}}
    {{#if hasEffect}}
    <div class="vce-tc-row">
      <label class="vce-tc-label vce-tc-inline">
        <input type="checkbox" name="includeEffect" />
        Include effect: <em>{{talent.system.effect}}</em>
        <span class="vce-tc-cost-note">(+1 Mana if paired with damage)</span>
      </label>
    </div>
    {{/if}}

    {{!-- Delivery --}}
    <div class="vce-tc-row">
      <label class="vce-tc-label" for="vce-tc-delivery">Delivery</label>
      <select name="delivery" id="vce-tc-delivery" class="vce-tc-select">
        {{#each deliveryOptions}}
          <option value="{{key}}" {{#if disabled}}disabled{{/if}}>
            {{key}}
            {{#if cost}}(+{{cost}} Mana){{else}}(free){{/if}}
          </option>
        {{/each}}
      </select>
    </div>

    {{!-- Duration --}}
    <div class="vce-tc-row">
      <span class="vce-tc-label">Duration <span class="vce-tc-cost-note">(always free)</span></span>
      <div class="vce-tc-radio-group">
        <label class="vce-tc-radio-label">
          <input type="radio" name="duration" value="instant" checked />
          Instant
        </label>
        <label class="vce-tc-radio-label">
          <input type="radio" name="duration" value="focus" />
          Focus
        </label>
      </div>
    </div>

  </div>{{!-- .vce-tc-body --}}

</form>
