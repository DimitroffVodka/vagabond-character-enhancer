<div class="vce-controller-dialog">
  <p class="vce-cd-intro">
    Configure save routing for <strong>{{npcName}}</strong>.
  </p>

  <div class="vce-cd-field">
    <label for="vce-controller-pc" class="vce-cd-label">Controller PC</label>
    <select id="vce-controller-pc" name="controllerId" class="vce-cd-select">
      <option value="">— Select —</option>
      {{#each pcChoices}}
        <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
      {{/each}}
    </select>
  </div>

  <fieldset class="vce-cd-field vce-cd-fieldset">
    <legend class="vce-cd-label">Type</legend>
    {{#each types}}
      <label class="vce-cd-radio">
        <input type="radio" name="controllerType" value="{{value}}" {{#if checked}}checked{{/if}}>
        <span class="vce-cd-radio-text">
          <span class="vce-cd-radio-title">{{label}}</span>
          {{#if hint}}<span class="vce-cd-radio-hint">{{hint}}</span>{{/if}}
        </span>
      </label>
    {{/each}}
  </fieldset>

  <footer class="vce-cd-footer">
    <button type="button" class="vce-cd-clear" data-action="clear">
      <i class="fas fa-trash"></i> Clear
    </button>
    <button type="submit" class="vce-cd-save">
      <i class="fas fa-save"></i> Save
    </button>
  </footer>
</div>
