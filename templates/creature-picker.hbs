<form class="vce-creature-picker">
  <div class="vce-cp-header">
    {{#if showSearch}}
      <input type="text" class="vce-cp-search" placeholder="Search creatures…" aria-label="Search creatures by name" autocomplete="off">
    {{/if}}
    {{#if multi}}
      <p class="vce-cp-budget">
        {{maxHDLabel}} — Selected: <span class="vce-cp-selected-count">0</span>
        · HD used: <span class="vce-cp-used-hd">0</span>
        {{#if hasFavorites}} · Right-click a row to favorite.{{/if}}
        · <em>Click to add, Shift-click to remove.</em>
      </p>
    {{else}}
      {{#if maxHDLabel}}
        <p class="vce-cp-budget">{{maxHDLabel}}{{#if hasFavorites}} · Right-click a row to favorite.{{/if}}</p>
      {{else}}
        {{#if hasFavorites}}
          <p class="vce-cp-budget">Right-click a row to favorite.</p>
        {{/if}}
      {{/if}}
    {{/if}}
  </div>

  <div class="vce-bd-scroll vce-cp-scroll">
    <table class="vce-bd-table vce-cp-table">
      <thead>
        <tr class="vce-bd-header-row">
          {{#if hasFavorites}}<th class="vce-bd-th vce-bd-th-center vce-cp-sort vce-cp-th-fav" data-sort="fav" scope="col" title="Sort by favorite">★</th>{{/if}}
          <th class="vce-bd-th vce-bd-th-img" scope="col"></th>
          <th class="vce-bd-th vce-cp-sort" data-sort="name" scope="col">Creature <span class="vce-cp-sort-arrow"></span></th>
          <th class="vce-bd-th vce-bd-th-center vce-cp-sort" data-sort="hd" scope="col">HD <span class="vce-cp-sort-arrow"></span></th>
          <th class="vce-bd-th vce-bd-th-center vce-cp-sort" data-sort="beingtype" scope="col">Type <span class="vce-cp-sort-arrow"></span></th>
          <th class="vce-bd-th vce-bd-th-center vce-cp-sort" data-sort="size" scope="col">Size <span class="vce-cp-sort-arrow"></span></th>
          <th class="vce-bd-th vce-bd-th-center vce-cp-sort" data-sort="hp" scope="col">HP <span class="vce-cp-sort-arrow"></span></th>
          <th class="vce-bd-th vce-bd-th-center vce-cp-sort" data-sort="armor" scope="col">Armor <span class="vce-cp-sort-arrow"></span></th>
          <th class="vce-bd-th vce-cp-sort" data-sort="speed" scope="col">Speed <span class="vce-cp-sort-arrow"></span></th>
          <th class="vce-bd-th" scope="col">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each creatures}}
          <tr class="vce-cp-row" data-uuid="{{uuid}}" data-name="{{name}}" data-hd="{{hd}}" data-beingtype="{{beingType}}" data-size="{{sizeOrder}}" data-hp="{{hp}}" data-armor="{{armor}}" data-speed="{{speed}}" data-favorite="{{#if isFavorite}}1{{else}}0{{/if}}" role="button" tabindex="0"{{#if ../hasFavorites}} aria-keyshortcuts="f"{{/if}}>
            {{#if ../hasFavorites}}
              <td class="vce-bd-cell vce-bd-cell-center vce-cp-fav">
                {{#if isFavorite}}
                  <i class="fas fa-star vce-cp-fav-on" role="img" aria-label="Favorited" title="Favorited — right-click or press F to unfavorite"></i>
                {{else}}
                  <i class="far fa-star vce-cp-fav-off" role="img" aria-label="Not favorited" title="Right-click or press F to favorite"></i>
                {{/if}}
              </td>
            {{/if}}
            <td class="vce-bd-cell vce-bd-cell-img">
              <img src="{{img}}" class="vce-bd-beast-img" alt="{{name}}" />
            </td>
            <td class="vce-bd-cell"><strong>{{name}}</strong></td>
            <td class="vce-bd-cell vce-bd-cell-center">{{hd}}</td>
            <td class="vce-bd-cell vce-bd-cell-center">{{beingType}}</td>
            <td class="vce-bd-cell vce-bd-cell-center">{{size}}</td>
            <td class="vce-bd-cell vce-bd-cell-center">{{hp}}</td>
            <td class="vce-bd-cell vce-bd-cell-center">{{armor}}</td>
            <td class="vce-bd-cell">{{speedStr}}</td>
            <td class="vce-bd-cell vce-bd-cell-actions">{{actionsStr}}</td>
          </tr>
        {{else}}
          <tr><td colspan="10" class="vce-bd-cell vce-cp-empty-row">No creatures match the filter.</td></tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <footer class="vce-cp-footer">
    {{#if multi}}
      <button type="button" class="vce-cp-confirm" data-action="confirm">
        <i class="fas fa-check"></i> Summon Selected
      </button>
    {{/if}}
    <button type="button" class="vce-cp-cancel" data-action="cancel">Cancel</button>
  </footer>
</form>
